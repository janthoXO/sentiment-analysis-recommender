DEBUG=true
PORT=3001

CACHE_URL=redis://localhost:6379
DB_URL=postgresql://sentinel:sentinel@localhost:5432/sentinel
RABBITMQ_URL=amqp://sentinel:sentinel@localhost:5672

TRACKER_URL=http://localhost:3032/api

FINNHUB_API_KEY=your_key_here

# Optional LLM theme search. Keep disabled unless GEMINI_API_KEY is configured.
LLM_PROVIDER=none
LLM_MODEL=gemini-2.5-flash-lite
GEMINI_API_KEY=
LLM_THEME_MAX_TICKERS=5
LLM_THEME_CONFIDENCE_THRESHOLD=0.6

# Optional LLM sentiment explanations. Uses cached batch prompts when enabled.
LLM_INSIGHT_ENABLED=false
LLM_INSIGHT_BATCH_SIZE=6
LLM_INSIGHT_MAX_ARTICLES=6
LLM_INSIGHT_TIMEOUT_MS=8000
CACHE_TTL_INSIGHT_SEC=3600
