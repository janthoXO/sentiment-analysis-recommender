RABBITMQ_URL=amqp://sentinel:sentinel@localhost:5672
MQ_EXCHANGE=sentinel.analyze
MQ_TASK_QUEUE=tasks
MQ_RESULT_ROUTING_KEY=result

# Scorer backend: "nli" (hypothesis-based) or "finbert" (financial classifier).
SCORER_TYPE=nli

# Model override. If left unset, defaults to the model matching SCORER_TYPE:
#   nli     -> cross-encoder/nli-deberta-v3-base
#   finbert -> ProsusAI/finbert
# MODEL_NAME=cross-encoder/nli-deberta-v3-base

# Only used by the "nli" backend.
HYPOTHESIS_POSITIVE=The company's stock price will go up.
HYPOTHESIS_NEGATIVE=The company's stock price will go down.

LOG_LEVEL=INFO
PREFETCH_COUNT=1
CACHE_TTL_SECONDS=3600
