{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TickerResult",
  "type": "object",
  "properties": {
    "stock": { "$ref": "./Stock.json" },
    "sources": {
      "type": "array",
      "items": {
        "$ref": "./SourceResult.json"
      }
    },
    "avgScore": {
      "type": "number",
      "minimum": -1.0,
      "maximum": 1.0
    },
    "investmentInsight": {
      "$ref": "./InvestmentInsight.json"
    },
    "eventTSec": {
      "type": "integer",
      "description": "The timestamp (in seconds) of the associated event."
    }
  },
  "required": ["stock", "sources", "avgScore"]
}
