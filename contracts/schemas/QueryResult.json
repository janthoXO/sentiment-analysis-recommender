{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "QueryResult",
  "type": "object",
  "properties": {
    "stock": { "$ref": "./Stock.json" },
    "sources": {
      "type": "array",
      "items": {
        "allOf": [
          { "$ref": "./Source.json" },
          {
            "type": "object",
            "properties": {
              "score": {
                "type": "number",
                "minimum": -1.0,
                "maximum": 1.0
              }
            },
            "required": ["url", "snippet", "score"]
          }
        ]
      }
    },
    "score": {
      "type": "number",
      "minimum": -1.0,
      "maximum": 1.0
    }
  },
  "required": ["stock", "sources", "score"]
}
