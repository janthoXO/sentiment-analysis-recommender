{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Source",
  "type": "object",
  "properties": {
    "url": { "type": "string", "format": "uri" },
    "snippet": { "type": "string" },
    "updatedAtSec": {
      "type": "number",
      "description": "Timestamp of the last update moment in seconds since Unix epoch",
      "minimum": 0
    },
    "scrapedAtSec": {
      "type": "number",
      "description": "Timestamp of the scrape moment in seconds since Unix epoch",
      "minimum": 0
    }
  },
  "required": ["url", "snippet", "scrapedAtSec", "updatedAtSec"]
}
