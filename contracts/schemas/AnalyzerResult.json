{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AnalyzerResult",
  "type": "object",
  "properties": {
    "scanJobId": { "type": "string", "format": "uuid" },
    "ticker": { "type": "string" },
    "score": {
      "type": "number",
      "minimum": -1.0,
      "maximum": 1.0,
      "description": "The sentiment score generated by FinBERT."
    },
    "snippet": { "type": "string" },
    "url": { "type": "string", "format": "uri" }
  },
  "required": ["ticker", "score", "snippet", "url"]
}
