{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InvestmentInsight",
  "type": "object",
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["bullish", "bearish", "neutral", "mixed"]
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "reasons": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "disclaimer": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": ["verdict", "confidence", "summary", "reasons", "disclaimer"]
}
